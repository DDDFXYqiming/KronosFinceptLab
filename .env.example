# =============================================================================
# KronosFinceptLab Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
# =============================================================================

# ---------- Kronos Model Paths ----------
# Windows path to the Kronos source repo (used by predictor)
KRONOS_REPO_PATH=E:/AI_Projects/KronosFinceptLab/external/Kronos
# Windows path to the HF cache / model weights
HF_HOME=E:/AI_Projects/KronosFinceptLab/external
# One shared Kronos model for Web/API/CLI/Agent.
KRONOS_MODEL_ID=NeoQuasar/Kronos-base
KRONOS_PREWARM_ON_STARTUP=0

# ---------- Data Sources ----------
# BaoStock (free, no key needed)
# AkShare (free, no key needed but may be rate-limited)
# Yahoo Finance (free, no key needed)

# ---------- LLM Providers (v6.0 AI Agents) ----------

# OpenAI / compatible APIs
OPENAI_API_KEY=sk-xxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-xxxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# DeepSeek
DEEPSEEK_API_KEY=sk-xxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# OpenRouter Free-first degradation mode.
# When OPENROUTER_API_KEY is configured, analysis and macro semantic routing
# try OPENROUTER_MODEL first, then fall back to DeepSeek on HTTP/timeout/JSON failure.
OPENROUTER_API_KEY=sk-or-xxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openrouter/free

# ---------- Server Config ----------
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# ---------- Logging ----------
# Local default stays human-readable; Zeabur Docker image overrides to json stdout.
KRONOS_LOG_LEVEL=INFO
KRONOS_LOG_FORMAT=text
KRONOS_LOG_ENABLE_FILE=1
KRONOS_LOG_DIR=logs
KRONOS_LOG_RETENTION_DAYS=14
KRONOS_LOG_MAX_BYTES=10485760
